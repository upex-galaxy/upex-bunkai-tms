{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebSearch",
      "WebFetch",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(tree *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(acli *)",
      "Bash(resend *)",
      "Bash(supabase *)",
      "mcp__context7__*",
      "mcp__tavily__*",
      "mcp__atlassian__*",
      "mcp__playwright__*",
      "mcp__dbhub__*",
      "mcp__openapi__*",
      "mcp__supabase__*",
      "Skill(agentic-dev-core)",
      "Skill(project-foundation)",
      "Skill(project-bootstrap)",
      "Skill(product-management)",
      "Skill(sprint-development)",
      "Skill(unit-testing)",
      "Skill(acli)",
      "Skill(git-flow-master)",
      "Skill(agentic-dev-onboard)",
      "Skill(sync-ai-memory)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git branch -D *)",
      "Bash(chmod 777 *)",
      "Bash(truncate *)",
      "Bash(shred *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)"
    ],
    "ask": []
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "BASH_MAX_OUTPUT_LENGTH": "20000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "includeCoAuthoredBy": false,
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7",
    "tavily",
    "atlassian",
    "playwright",
    "dbhub",
    "openapi",
    "supabase"
  ],
  "cleanupPeriodDays": 30
}
