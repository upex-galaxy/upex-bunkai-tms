{
  "mcpServers": {
    "context7": {
      "command": "bunx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "tavily": {
      "command": "bunx",
      "args": ["-y", "mcp-remote", "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}"]
    },
    "supabase": {
      "command": "bunx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}"
      ],
      "env": {
        "SUPABASE_URL": "${NEXT_PUBLIC_SUPABASE_URL}",
        "SUPABASE_ANON_KEY": "${SUPABASE_PUBLISHABLE_KEY}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SECRET_KEY}"
      }
    },
    "dbhub": {
      "command": "bunx",
      "args": ["-y", "@bytebase/dbhub@latest", "--config", "dbhub.toml"]
    },
    "openapi": {
      "command": "bunx",
      "args": ["-y", "@ivotoby/openapi-mcp-server", "--tools", "dynamic"],
      "env": {
        "API_BASE_URL": "${API_BASE_URL}",
        "OPENAPI_SPEC_PATH": "${OPENAPI_SPEC_PATH}",
        "API_HEADERS": "Authorization:Bearer ${API_TOKEN}"
      }
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest",
        "--caps",
        "vision,pdf,testing,tracing,tabs",
        "--timeout-action",
        "10000",
        "--timeout-navigation",
        "30000",
        "--viewport-size",
        "1920x1080"
      ]
    },
    "postman": {
      "type": "http",
      "url": "https://mcp.postman.com/mcp",
      "headers": { "Authorization": "Bearer ${POSTMAN_API_KEY}" }
    }
  }
}
