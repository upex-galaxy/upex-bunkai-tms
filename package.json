    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "figures": "^6.1.0",
    "lucide-react": "^1.16.0",
    "next": "^15",
    "picocolors": "^1.1.1",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.0",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4",
    "typescript": "^5.9.3"
