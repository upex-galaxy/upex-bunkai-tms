# ============================================================================
#* AI-DRIVEN SOFTWARE PROJECT - ENVIRONMENT VARIABLES
# ============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values (see comments below)
# 3. Never commit .env to git (it's in .gitignore)
#
# Documentation: docs/mcp-builder-strategy.md
# ============================================================================

# ----------------------------------------------------------------------------
#* MCP BUILDER CONFIGURATION (Required for AI tools integration)
# ----------------------------------------------------------------------------
# See: docs/mcp-builder-strategy.md for detailed setup instructions

# Path to your MCP catalog file (contains ALL available MCPs with your API keys)
# This file is NOT committed to git and contains your secrets
# Example values:
#   - Gemini CLI:    '.gemini/settings.catalog.json'
#   - Claude Code:   '.mcp.catalog.json'
#   - Cursor:        '.cursor/mcp.catalog.json'
MCP_CATALOG_FILE='.gemini/settings.catalog.json'

# Path to the active MCP config file (auto-generated by mcp-builder.js)
# This is the file your AI tool actually reads
# Example values:
#   - Gemini CLI:    '.gemini/settings.json'
#   - Claude Code:   '.mcp.json'
#   - Cursor:        '.cursor/mcp.json'
MCP_FILE='.gemini/settings.json'

# Path to your AI CLI binary (OPTIONAL - only needed for auto-launch)
# Leave empty or omit if you prefer to launch your AI tool manually
# Example values:
#   - Gemini CLI:    '/path/to/gemini' or '~/.nvm/versions/node/vX.X.X/bin/gemini'
#   - Claude Code:   '/usr/local/bin/claude'
#   - Cursor:        '/usr/local/bin/cursor'
AI_COMMAND_PATH=''

# ----------------------------------------------------------------------------
#* ALTERNATIVE CONFIGURATIONS (Examples for different AI tools)
# ----------------------------------------------------------------------------
# Uncomment and use the configuration that matches your AI tool:

# Claude Code (Anthropic CLI):
# MCP_CATALOG_FILE='.mcp.catalog.json'
# MCP_FILE='.mcp.json'
# AI_COMMAND_PATH='/usr/local/bin/claude'

# GitHub Copilot CLI:
# MCP_CATALOG_FILE='.copilot/mcp.catalog.json'
# MCP_FILE='.copilot/mcp.json'
# AI_COMMAND_PATH=''

# Cursor IDE:
# MCP_CATALOG_FILE='.cursor/mcp.catalog.json'
# MCP_FILE='.cursor/mcp.json'
# AI_COMMAND_PATH='/usr/local/bin/cursor'

# ----------------------------------------------------------------------------
#* AI AGENT MCP SERVERS (Required for committed .mcp.json / opencode.jsonc)
# ----------------------------------------------------------------------------
# These files are committed to git and reference env vars via:
#   - .mcp.json (Claude Code) → ${VAR_NAME} / ${VAR:-default}  (FAILS if missing)
#   - opencode.jsonc          → {env:VAR_NAME}                  (empty string if missing)
#
# Two ways to load these vars before launching the agent:
#
#   A) Cross-platform wrapper (default, works on Windows/Mac/Linux):
#        bun run claude       → wraps `claude` with dotenv-cli
#        bun run opencode     → idem
#
#   B) Optional, Mac/Linux only: direnv auto-loads on `cd` into the repo.
#      See .envrc for the one-time setup. Once configured, you can run
#      `claude` / `opencode` directly — direnv exports .env into your shell.
# ----------------------------------------------------------------------------

# Tavily (web search MCP) — https://app.tavily.com/
TAVILY_API_KEY=

# === Atlassian credentials (single source of truth — DRY) ===
# One family of vars covers EVERY Atlassian consumer in this repo:
#   - acli CLI (skill .claude/skills/acli)
#   - scripts/sync-jira-*.ts (raw REST calls)
#   - cli/install.ts auth loop
#   - (opt-in) MCP atlassian server — see docs/mcp/ for the templates if you want to enable it
# No JIRA_* credential overrides. Naming rule:
#   - ATLASSIAN_*  = credentials
#   - JIRA_*       = operational (project key, output dir, custom field, etc.)
ATLASSIAN_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
# Get a token at: https://id.atlassian.com/manage-profile/security/api-tokens

# === Jira operational params (NOT credentials) ===
# Default project key for `bun run jira:sync-issues` (else falls back to .agents/project.yaml).
# JIRA_PROJECT=
# Output directory for synced issues (default: .context/PBI).
# JIRA_SYNC_OUTPUT=

# Supabase MCP — personal access token + project API keys
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# n8n MCP — your n8n instance API URL + key
N8N_API_URL=
N8N_API_KEY=

# ----------------------------------------------------------------------------
#* Configuración de Supabase (Requerido)
# ----------------------------------------------------------------------------
# Encuentra estos valores en tu panel de Supabase en Settings > API:
SUPABASE_URL= La URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY= La clave anónima pública de tu proyecto Supabase
SUPABASE_SERVICE_ROLE_KEY= La clave de rol de servicio de tu proyecto Supabase

#! CONSEJO: Si quieres copiar todas las variables de Supabase, puedes ir a la pestaña Project Storage en Vercel:
# 1. Ve a tu Vercel Project Storage: https://vercel.com/{organization-name}/{project-name}/stores (reemplaza los valores entre llaves)
# 2. Selecciona tu proyecto de Supabase (database)
# 3. Copia las variables de entorno desde Quickstart (haciendo clic en el botón "Copy Snippet")
# 4. Pégalas en tu archivo .env

# ----------------------------------------------------------------------------
#* Configuración de la Aplicación
# ----------------------------------------------------------------------------
# La URL base de tu aplicación, utilizada para redirecciones de autenticación.
# En desarrollo local, generalmente es http://localhost:3000, pero en producción será la URL de tu ambiente deployado.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser (Next.js)
# - Never commit real values to git
# - Keep this .env.example file updated when adding new variables
# - Use descriptive comments to help your team understand each variable
# - For local development, you might want to create .env (also gitignored)
# ----------------------------------------------------------------------------
