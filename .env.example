# ============================================================================
#* AI-DRIVEN SOFTWARE PROJECT - ENVIRONMENT VARIABLES
# ============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values (see comments below)
# 3. Never commit .env to git (it's in .gitignore)
#
# Documentation: docs/mcp-builder-strategy.md
# ============================================================================

# ----------------------------------------------------------------------------
#* AI AGENT MCP SERVERS — loading mechanics
# ----------------------------------------------------------------------------
# .mcp.json (Claude Code) and opencode.jsonc are committed to git and reference
# env vars via expansion:
#   - .mcp.json      → ${VAR_NAME} / ${VAR:-default}  (FAILS if missing)
#   - opencode.jsonc → {env:VAR_NAME}                 (empty string if missing)
#
# Two ways to load these vars before launching the agent:
#
#   A) Cross-platform wrapper (default, works on Windows/Mac/Linux):
#        bun run claude     → wraps `claude` with dotenv-cli
#        bun run opencode   → idem
#
#   B) Optional, Mac/Linux only: direnv auto-loads on `cd` into the repo.
#      See .envrc for the one-time setup. Once configured, run
#      `claude` / `opencode` directly — direnv exports .env into your shell.
# ----------------------------------------------------------------------------


# ============================================================================
#* ATLASSIAN — single source of truth (DRY)
# ============================================================================
# One family of vars covers EVERY Atlassian consumer in this repo:
#   - acli CLI (skill .claude/skills/acli)
#   - scripts/sync-jira-*.ts (raw REST calls)
#   - cli/install.ts auth loop
#   - (opt-in) MCP atlassian server — see docs/mcp/ to enable it manually
#
# Naming rule:
#   - ATLASSIAN_*  = credentials
#   - JIRA_*       = operational (project key, output dir, custom field, etc.)
#
# Get an API token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# --- Jira operational params (NOT credentials) ---
# Default project key for `bun run jira:sync-issues` (else .agents/project.yaml).
# JIRA_PROJECT_KEY=
# Output directory for synced issues (default: .context/PBI).
# JIRA_SYNC_OUTPUT=


# ============================================================================
#* SEARCH / DOCS MCPs
# ============================================================================
# Tavily — web search MCP — https://app.tavily.com/
TAVILY_API_KEY=


# ============================================================================
#* AUTOMATION MCPs
# ============================================================================
# n8n MCP — workflow automation instance
N8N_API_URL=
N8N_API_KEY=


# ============================================================================
#* QA TESTING MCPs — DBHub (DB) · OpenAPI + Postman (API) · Playwright (UI)
# ============================================================================
# Consumed by the in-app /qa "Software Testability Guide for QA" page and the
# four testing MCPs wired in .mcp.json / opencode.jsonc. Names only — real
# values live in your local .env and in the credentials Epic (BK-29).
#
# DBHub MCP (@bytebase/dbhub, config dbhub.toml). Connect via the Supabase
# SESSION pooler (port 5432) with a read-only QA role.
# FOOTGUN: a missing var substitutes literally -> verify with: env | grep DBHUB
DBHUB_TYPE=postgres                  # sqlserver | postgres | mysql | sqlite | mariadb
DBHUB_HOST=                          # e.g. aws-1-<region>.pooler.supabase.com
DBHUB_PORT=5432                      # 5432 session pooler (QA) · 6543 transaction pooler
DBHUB_DATABASE=postgres
DBHUB_USER=                          # qa_inspector_ro.<project-ref>
DBHUB_PASSWORD=                      # from credentials Epic — never commit

# OpenAPI MCP (@ivotoby/openapi-mcp-server --tools dynamic).
API_BASE_URL=http://localhost:3000/api
OPENAPI_SPEC_PATH=http://localhost:3000/api/openapi
API_TOKEN=                           # Bearer PAT (bk_pat_*) minted via POST /api/v1/auth/signin

# Postman MCP (https://mcp.postman.com/mcp). Generate at postman.com -> API Keys.
POSTMAN_API_KEY=


# ============================================================================
#* RESEND — Transactional email
# ============================================================================
# Get a key: https://resend.com/api-keys
# Docs: https://resend.com/docs/api-reference/introduction
# Used by application code AND for `resend` CLI authentication
# (CLI also supports browser auth: `resend login`).
RESEND_API_KEY=


# ============================================================================
#* SUPABASE — MCP control plane
# ============================================================================
# Personal Access Token for Supabase MCP (project management, migrations,
# advisors, edge functions). Admin-scope.
# Get token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=


# ============================================================================
#* SUPABASE — Project Backend (Required)
# ============================================================================
# Find these values in Supabase Dashboard → Settings → API
# Using NEW-STYLE keys (publishable + secret). Legacy anon/service_role keys
# are intentionally NOT listed here — modern Supabase projects use the new pair.
# The Vercel+Supabase integration generates ONLY NEXT_PUBLIC_SUPABASE_URL (no
# server-side SUPABASE_URL counterpart) — server code should read the
# NEXT_PUBLIC_* var directly, and `.mcp.json` / `opencode.jsonc` already
# bridge it into the Supabase MCP server's expected SUPABASE_URL env name.
NEXT_PUBLIC_SUPABASE_URL=           # https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=           # publishable key (browser-safe)
SUPABASE_SECRET_KEY=                # secret key (server only)
SUPABASE_JWT_SECRET=                # sign / verify custom JWTs

#! TIP: Copy all Supabase vars at once from Vercel:
# 1. Open Vercel Project Storage: https://vercel.com/{org}/{project}/stores
# 2. Select your Supabase store (database)
# 3. Quickstart → "Copy Snippet"
# 4. Paste into your .env


# ============================================================================
#* POSTGRES — direct connection (Required if using Prisma / raw SQL)
# ============================================================================
POSTGRES_HOST=                      # db.<project-ref>.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres
POSTGRES_URL=                       # pooled (port 6543, supa=base-pooler.x)
POSTGRES_URL_NON_POOLING=           # direct (port 5432)
POSTGRES_PRISMA_URL=                # pooled + pgbouncer=true (Prisma)


# ============================================================================
#* APP CONFIG (Required)
# ============================================================================
# Base URL for auth redirects, OAuth callbacks, email links.
# Local dev: http://localhost:3000 | Production: your deployed URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser (Next.js)
# - Never commit real values to git
# - Keep this .env.example file updated when adding new variables
# - Use descriptive comments to help your team understand each variable
# ----------------------------------------------------------------------------
